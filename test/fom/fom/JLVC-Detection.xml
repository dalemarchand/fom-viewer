                <parameter>
                    <name>SensingEntityList</name>
                    <dataType>LVCIDArray</dataType>
                    <semantics>LVC IDs of sensing entity or aggregate. Mandatory</semantics>
                </parameter>
                <parameter>
                    <name>TargetList</name>
                    <dataType>LVCIDArray</dataType>
                    <semantics>LVC IDs of the targets that have been detected. Mandatory</semantics>
                </parameter>
                <parameter>
                    <name>Type</name>
                    <dataType>TypeOfDetectionEnum8</dataType>
                    <semantics>Method of detection (TypeOfDetectionEnum8). Optional</semantics>
                </parameter>
                <parameter>
                    <name>Relationship</name>
                    <dataType>ForceIDEnum8</dataType>
                    <semantics>Perceived relationship with the sensing object.Mandatory</semantics>
                </parameter>
