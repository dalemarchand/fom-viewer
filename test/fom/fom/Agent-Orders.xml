                </parameter>
                <parameter>
                    <name>SupplyList</name>
                    <dataType>SupplyDetailsStructArray1Plus</dataType>
                    <semantics>details about the supplies being transferred.</semantics>
                </parameter>
            </interactionClass>
        </interactionClass>
    </interactions>
