<?xml version="1.0" encoding="UTF-8"?>
<objectModel xsi:schemaLocation="http://standards.ieee.org/IEEE1516-2010 http://standards.ieee.org/downloads/1516/1516.2-2010/IEEE1516-DIF-2010.xsd" xmlns="http://standards.ieee.org/IEEE1516-2010" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <modelIdentification>
        <name>Agent-Orders</name>
        <type>FOM</type>
        <version>0_7</version>
        <modificationDate>2025-08-27</modificationDate>
        <securityClassification>Unclassified</securityClassification>
        <purpose>Agent-Orders provides capabilities for allowing federate entities to be remotely controlled (RC) by an agent, along with control commands for the agent to use.</purpose>
        <applicationDomain>Training</applicationDomain>
        <description>This FOM module contains the objects and interactions necessary for remote Agent-based control.</description>
        <useLimitation/>
        <useHistory>0_1 - Initial Draft of Agent-Orders module</useHistory>
        <useHistory>0_2 (2025-01-20)- Replaced Radar with more generic 'detection'</useHistory>
        <useHistory>0_3 (2025-01-23)- Fixed mis-spelled RTIobjectId datatypes</useHistory>
        <useHistory>0_4 (2025-02-03)- Replaced duplicate AgentID in UpdateEntity with Formation</useHistory>
        <useHistory>0_5 (2025-02-03)- Draft 2</useHistory>
        <useHistory>0_7 (2025-08-27)- Updated the version number to match the version number in the filename posted on confluence. This version will be added to JLVC CY25 Final as a preview module.</useHistory>
