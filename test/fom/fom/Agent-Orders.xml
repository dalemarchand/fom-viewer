                </parameter>
                <parameter>
                    <name>Tracking</name>
                    <dataType>RPRboolean</dataType>
                    <semantics>Tracking or dropped</semantics>
                </parameter>
            </interactionClass>
            <interactionClass>
                <name>TransferSupplies</name>
                <sharing>PublishSubscribe</sharing>
                <transportation>HLAbestEffort</transportation>
                <order>Receive</order>
                <semantics>RC command to initiate a transfer of supplies from one entity to another</semantics>
                <parameter>
                    <name>AgentID</name>
                    <dataType>HLAASCIIstring</dataType>
                    <semantics>ID of Agent controlling the [offering] entity</semantics>
