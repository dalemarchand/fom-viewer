                    <value>8</value>
                </enumerator>
                <enumerator>
                    <name>ENTITYPULL_TEST</name>
                    <value>9</value>
                </enumerator>
                <enumerator>
                    <name>ACCEPTED</name>
                    <value>10</value>
                </enumerator>
                <enumerator>
                    <name>REFUSED</name>
                    <value>11</value>
                </enumerator>
                <enumerator>
                    <name>ALREADYOWNED</name>
                    <value>12</value>
                </enumerator>
                <enumerator>
                    <name>INSUFFICIENTDATA</name>
                    <value>13</value>
                </enumerator>
                <enumerator>
                    <name>INSUFFICIENTFUEL</name>
                    <value>14</value>
                </enumerator>
                <enumerator>
                    <name>OUTSIDEOFPLAYBOX</name>
                    <value>15</value>
                </enumerator>
                <enumerator>
                    <name>UNKNOWNOBJECT</name>
                    <value>16</value>
                </enumerator>
                <enumerator>
                    <name>CONFLICT</name>
                    <value>17</value>
                </enumerator>
                <enumerator>
                    <name>REPUBLISH</name>
                    <value>18</value>
                </enumerator>
                <enumerator>
                    <name>RELEASE_NOTIFICATION</name>
                    <value>19</value>
                </enumerator>
                <enumerator>
                    <name>TRANSFER_COMPLETE</name>
                    <value>20</value>
                </enumerator>
                <enumerator>
                    <name>TRANSFER_FAILED</name>
                    <value>21</value>
                </enumerator>
                <enumerator>
                    <name>ACCEPTED_WITH_ADDITIONS</name>
                    <value>22</value>
                </enumerator>
                <enumerator>
                    <name>ACCEPTED_ADDITIONS</name>
                    <value>23</value>
                </enumerator>
                <enumerator>
                    <name>UNKNOWN_REQUEST</name>
                    <value>24</value>
                </enumerator>
            </enumeratedData>
        </enumeratedDataTypes>
        <arrayDataTypes>
            <arrayData>
                <name>HLAASCIIcharArray32</name>
                <dataType>HLAASCIIchar</dataType>
                <cardinality>32</cardinality>
                <encoding>HLAfixedArray</encoding>
                <semantics>an array of 32 ASCII characters</semantics>
            </arrayData>
        </arrayDataTypes>
    </dataTypes>
</objectModel>
