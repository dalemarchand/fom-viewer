<?xml version="1.0" encoding="UTF-8"?>
<objectModel xsi:schemaLocation="http://standards.ieee.org/IEEE1516-2010 http://standards.ieee.org/downloads/1516/1516.2-2010/IEEE1516-DIF-2010.xsd" xmlns="http://standards.ieee.org/IEEE1516-2010" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <modelIdentification>
        <name>JLVC-SIMAN</name>
        <type>FOM</type>
        <version>5</version>
        <modificationDate>2026-01-16</modificationDate>
        <securityClassification>Unclassified</securityClassification>
        <purpose>JLVC-SIMAN provides components neccessary for simulation management in the JLVC federation.</purpose>
        <applicationDomain>Training</applicationDomain>
        <description>This FOM module contains the objects and interactions used for simulation management the JLVC Federation.</description>
        <useLimitation/>
        <useHistory>JLVC2024 - Draft 1 of the JLVC Modular FOM. Removed redundant count parameter NumInactiveEntities from JLVC_TransferOwnership interaction.</useHistory>
        <useHistory>JLVC2024 - JSJ7JLVC-21714: Refactor Area_Of_Interest object to enforce dependencies on GeometryType: Created new Area2DVariantStruct. Created PolygonGeometryStruct. Created CircleGeometryStruct. Created EllipseGeometryStruct. Created RectangleGeometryStruct. Updated Area_Of_Interest object to use Area2DVariantStruct. Updated semantics for GeometryTypeEnum8.</useHistory>
        <useHistory>JLVC2024 - Updated version number from 2024 to 2.</useHistory>
        <useHistory>JLVC2024 - Fixed extra space at the end of PolygonGeometryStruct</useHistory>
        <useHistory>JLVC2025 - Version 4: Moved Area2DVariantStruct and associated dataTypes to JLVC-Base. Removed duplicate TransferStatusEnum8 dataType. Updated AOI semantics to accurately describe the geometries as 2D.</useHistory>
        <useHistory>JLVC2026 - Version 5: Updated reference dependencies to use the new RPRv3 module names.</useHistory>
        <poc>
            <pocType>Primary author</pocType>
            <pocName>Heath Rush</pocName>
            <pocOrg>CAPE Technology Solutions</pocOrg>
            <pocEmail>heath.rush@capetechsolutions.com</pocEmail>
        </poc>
        <reference>
            <type>Dependency</type>
            <identification>SISO-STD-001.1-2025 - Real-time Platform Reference Base FOM Module</identification>
        </reference>
        <reference>
            <type>Dependency</type>
            <identification>SISO-STD-001.1-2025 - Real-time Platform Reference Enumerations FOM Module</identification>
        </reference>
        <reference>
            <type>Dependency</type>
            <identification>SISO-STD-001.1-2025 - Real-time Platform Reference Foundation FOM Module</identification>
        </reference>
        <reference>
            <type>Dependency</type>
            <identification>SISO-STD-001.1-2025 - Real-time Platform Reference Simulation Management FOM Module</identification>
        </reference>
        <reference>
            <type>Dependency</type>
            <identification>JLVC-Base</identification>
        </reference>
    </modelIdentification>
    <objects>
        <objectClass>
            <name>HLAobjectRoot</name>
            <objectClass>
                <name>Area_Of_Interest</name>
                <sharing>PublishSubscribe</sharing>
                <semantics>Initially to provide a mechanism to publish an object that will outline the as-played JCATS terrain box. AOIs are currently defined as two-dimensional geometries.</semantics>
                <attribute>
                    <name>AreaName</name>
                    <dataType>HLAASCIIstring</dataType>
                    <updateType>Conditional</updateType>
                    <updateCondition>on change</updateCondition>
                    <ownership>NoTransfer</ownership>
                    <sharing>PublishSubscribe</sharing>
                    <dimensions>
                        <dimension>subspace</dimension>
                        <dimension>one</dimension>
                        <dimension>two</dimension>
                    </dimensions>
                    <transportation>HLAbestEffort</transportation>
                    <order>Receive</order>
                    <semantics>The Name of the Area</semantics>
                </attribute>
                <attribute>
                    <name>OwningFederate</name>
                    <dataType>HLAASCIIstring</dataType>
                    <updateType>Conditional</updateType>
                    <updateCondition>on change</updateCondition>
                    <ownership>NoTransfer</ownership>
                    <sharing>PublishSubscribe</sharing>
                    <dimensions>
                        <dimension>subspace</dimension>
                        <dimension>one</dimension>
                        <dimension>two</dimension>
                    </dimensions>
                    <transportation>HLAbestEffort</transportation>
                    <order>Receive</order>
                    <semantics>The federate that owns this object. (Should include what version ie. JCATS1, JCATS2) </semantics>
                </attribute>
                <attribute>
                    <name>Geometry</name>
                    <dataType>Area2DVariantStruct</dataType>
                    <updateType>Conditional</updateType>
                    <updateCondition>on change</updateCondition>
                    <ownership>NoTransfer</ownership>
                    <sharing>PublishSubscribe</sharing>
                    <dimensions>
                        <dimension>subspace</dimension>
                        <dimension>one</dimension>
                        <dimension>two</dimension>
                    </dimensions>
                    <transportation>HLAbestEffort</transportation>
                    <order>Receive</order>
                    <semantics>Two-dimensional AOI geometry data including shape and fields to define that shape.</semantics>
                </attribute>
                <attribute>
                    <name>Type</name>
                    <dataType>HLAASCIIstring</dataType>
                    <updateType>Conditional</updateType>
                    <updateCondition>on change</updateCondition>
                    <ownership>NoTransfer</ownership>
                    <sharing>PublishSubscribe</sharing>
                    <dimensions>
                        <dimension>subspace</dimension>
                        <dimension>one</dimension>
                        <dimension>two</dimension>
                    </dimensions>
                    <transportation>HLAbestEffort</transportation>
                    <order>Receive</order>
                    <semantics>The type of AOI. (“Terrain”, … )</semantics>
                </attribute>
            </objectClass>
        </objectClass>
    </objects>
    <interactions>
        <interactionClass>
            <name>HLAinteractionRoot</name>
            <interactionClass>
                <name>MovementOrders</name>
                <sharing>PublishSubscribe</sharing>
                <dimensions>
                    <dimension>subspace</dimension>
                    <dimension>one</dimension>
                    <dimension>two</dimension>
                </dimensions>
                <transportation>HLAbestEffort</transportation>
                <order>Receive</order>
                <semantics>Allow external events, i.e. MESL events, to move entities</semantics>
                <parameter>
                    <name>alt</name>
                    <dataType>Float64</dataType>
                    <semantics/>
                </parameter>
                <parameter>
                    <name>formation</name>
                    <dataType>AggregateStateFormationEnum32</dataType>
                    <semantics/>
                </parameter>
                <parameter>
                    <name>from</name>
                    <dataType>EntityIdentifierStruct</dataType>
                    <semantics>Who sent this interaction</semantics>
                </parameter>
                <parameter>
                    <name>headingInDegs</name>
                    <dataType>UnsignedInteger16</dataType>
                    <semantics/>
                </parameter>
                <parameter>
                    <name>lat</name>
                    <dataType>LatitudeDegreesFloat64</dataType>
                    <semantics/>
                </parameter>
                <parameter>
                    <name>lon</name>
                    <dataType>LongitudeDegreesFloat64</dataType>
                    <semantics/>
                </parameter>
                <parameter>
                    <name>obsID</name>
                    <dataType>HLAASCIIcharArray32</dataType>
                    <semantics/>
                </parameter>
                <parameter>
                    <name>packedBooleans</name>
                    <dataType>UnsignedInteger16</dataType>
                    <semantics>0x01 AGL - if set use AGL, else MSL 0x02 Halt - unit Must Halt now or after movement 0x04 Magic - if set it\'s a Magic Move 0x08 - Change Formation - if set read formation enum</semantics>
                </parameter>
                <parameter>
                    <name>reason</name>
                    <dataType>UnsignedInteger16</dataType>
                    <semantics/>
                </parameter>
                <parameter>
                    <name>sequenceNumber</name>
                    <dataType>UnsignedInteger16</dataType>
                    <semantics>Combined with \"from\" gives an unique identification of this interaction</semantics>
                </parameter>
                <parameter>
                    <name>velInMph</name>
                    <dataType>Float64</dataType>
                    <semantics/>
                </parameter>
            </interactionClass>
            <interactionClass>
                <name>TransferOwnership</name>
                <interactionClass>
                    <name>JLVC_TransferOwnership</name>
                    <sharing>PublishSubscribe</sharing>
                    <dimensions>
                        <dimension>subspace</dimension>
                        <dimension>one</dimension>
                        <dimension>two</dimension>
                    </dimensions>
                    <transportation>HLAbestEffort</transportation>
                    <order>Receive</order>
                    <semantics>a transfer ownership interaction with JLVC agreed upon parameters</semantics>
                    <parameter>
                        <name>TransferTime</name>
                        <dataType>TransferTimeEnum8</dataType>
                        <semantics>Time of transfer</semantics>
                    </parameter>
                    <parameter>
                        <name>ActiveEntityList</name>
                        <dataType>RTIobjectIdArray</dataType>
                        <semantics>List of active IDs to be transferred.</semantics>
                    </parameter>
                    <parameter>
                        <name>InactiveEntityList</name>
                        <dataType>LVCIDArray</dataType>
                        <semantics>List of in-active JLVC IDs to be transferred.</semantics>
                    </parameter>
                    <parameter>
                        <name>ManifestList</name>
                        <dataType>RTIobjectIdArray</dataType>
                        <semantics>List of manifest objects to be transferred.</semantics>
                    </parameter>
                    <parameter>
                        <name>ScheduledTime</name>
                        <dataType>DateTime</dataType>
                        <semantics>Time the transfer will take place.</semantics>
                    </parameter>
                    <parameter>
                        <name>ErrorMessage</name>
                        <dataType>HLAASCIIstring</dataType>
                        <semantics>Optional text with details of unaccepted transfer.</semantics>
                    </parameter>
                    <parameter>
                        <name>TransferStatus</name>
                        <dataType>TransferStatusEnum8</dataType>
                        <semantics>Status of Unit Ownership Transfer</semantics>
                    </parameter>
                    <parameter>
                        <name>TransactionID</name>
                        <dataType>HLAASCIIstring</dataType>
                        <semantics>A unique identifier for the transaction for reference purposes.</semantics>
                    </parameter>
                    <parameter>
                        <name>AdditionalTransferTypes</name>
                        <dataType>TransferTypeAdditionsEnum8</dataType>
                        <semantics>Extends the TransferTypeEnum8 with additional enumerated values. If one of the TransferTypeAdditionsEnum8 values is used, the value of TransferControl.TransferType should be set equal to 0.</semantics>
                    </parameter>
                </interactionClass>
            </interactionClass>
        </interactionClass>
    </interactions>
    <dataTypes>
        <enumeratedDataTypes>
            <enumeratedData>
                <name>TransferStatusEnum8</name>
                <representation>RPRunsignedInteger8BE</representation>
                <semantics>Status of Unit Ownership Transfer</semantics>
                <enumerator>
                    <name>TransferStarted</name>
                    <value>0</value>
                </enumerator>
                <enumerator>
                    <name>TransferSuccessful</name>
                    <value>1</value>
                </enumerator>
                <enumerator>
                    <name>TransferFailed</name>
                    <value>2</value>
                </enumerator>
            </enumeratedData>
            <enumeratedData>
                <name>TransferTimeEnum8</name>
                <representation>RPRunsignedInteger8BE</representation>
                <semantics>-NULL-</semantics>
                <enumerator>
                    <name>Scheduled</name>
                    <value>2</value>
