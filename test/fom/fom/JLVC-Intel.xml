    <modelIdentification>
        <name>JLVC-Intel</name>
        <type>FOM</type>
        <version>2</version>
        <modificationDate>2026-01-16</modificationDate>
        <securityClassification>Unclassified</securityClassification>
        <purpose>JLVC-Intel provides Intel components neccessary for use in the JLVC federation.</purpose>
        <applicationDomain>Training</applicationDomain>
        <description>This FOM module contains the objects and interactions necessary for Intel communication in the JLVC Federation.</description>
        <useLimitation/>
        <useHistory>JLVC2024 - Draft 1 of the JLVC Modular FOM.</useHistory>
        <useHistory>JLVC2024 - Updated version number from 2024 to 1.</useHistory>
        <useHistory>JLVC2026 - Version 2: Updated reference dependencies to use the new RPRv3 module names. Added RPR Enumerations module as a reference dependency.</useHistory>
        <poc>
            <pocType>Primary author</pocType>
            <pocName>Heath Rush</pocName>
            <pocOrg>CAPE Technology Solutions</pocOrg>
            <pocEmail>heath.rush@capetechsolutions.com</pocEmail>
        </poc>
        <reference>
            <type>Dependency</type>
            <identification>SISO-STD-001.1-2025 - Real-time Platform Reference Base FOM Module</identification>
        </reference>
        <reference>
            <type>Dependency</type>
            <identification>SISO-STD-001.1-2025 - Real-time Platform Reference Foundation FOM Module</identification>
        </reference>
        <reference>
            <type>Dependency</type>
            <identification>SISO-STD-001.1-2025 - Real-time Platform Reference Enumerations FOM Module</identification>
        </reference>
        <reference>
            <type>Dependency</type>
            <identification>JLVC-Base</identification>
        </reference>
    </modelIdentification>
    <interactions>
        <interactionClass>
            <name>HLAinteractionRoot</name>
            <interactionClass>
                <name>AbstractIntent</name>
                <sharing>PublishSubscribe</sharing>
                <dimensions>
                    <dimension>subspace</dimension>
                    <dimension>one</dimension>
                    <dimension>two</dimension>
                </dimensions>
                <transportation>HLAbestEffort</transportation>
                <order>Receive</order>
                <semantics>This interaction is proposed to convey simulation truth or inteded observation of an \"event\" that could be used by intel federates. Specifically, this event ties radio emissions to exercise storylines.</semantics>
                <parameter>
                    <name>Sender</name>
                    <dataType>RTIobjectId</dataType>
                    <semantics>RTI Name of the sender of the action or intent</semantics>
                </parameter>
                <parameter>
                    <name>SenderEvent</name>
                    <dataType>EventIdentifierStruct</dataType>
                    <semantics>Event ID of the transaction from the sender</semantics>
                </parameter>
                <parameter>
                    <name>Receiver</name>
                    <dataType>RTIobjectId</dataType>
                    <semantics>RTI Name of the receiver or target of the action or intent</semantics>
                </parameter>
                <parameter>
                    <name>receiverEvent</name>
                    <dataType>EventIdentifierStruct</dataType>
                    <semantics>Event ID of the transaction from the receiver side</semantics>
                </parameter>
                <parameter>
                    <name>IntentType</name>
                    <dataType>AbstractIntentEnum16</dataType>
                    <semantics>Type of abstract intent generated by the simulation</semantics>
                </parameter>
                <parameter>
                    <name>eventTag</name>
                    <dataType>HLAASCIIstring</dataType>
                    <semantics>Exercise specific TAG or event key. ie. CrowdAction12</semantics>
                </parameter>
                <parameter>
                    <name>Misc</name>
                    <dataType>HLAASCIIstring</dataType>
                    <semantics>Placeholder for additional datagrams. This interaction is expected to evolve</semantics>
                </parameter>
                <parameter>
                    <name>Action</name>
                    <dataType>AbstractIntentActionEnum8</dataType>
                    <semantics>Type of action which is occurring.</semantics>
                </parameter>
                <parameter>
                    <name>ExchangeStyle</name>
                    <dataType>ExchangeStyleEnum16</dataType>
                    <semantics>Optional. Information exchange style or method.</semantics>
                </parameter>
            </interactionClass>
            <interactionClass>
                <name>CommsRequest</name>
                <sharing>PublishSubscribe</sharing>
                <dimensions>
                    <dimension>subspace</dimension>
                    <dimension>one</dimension>
                    <dimension>two</dimension>
                </dimensions>
                <transportation>HLAbestEffort</transportation>
                <order>Receive</order>
                <semantics>Used to request a logical communication between two entities. The interaction is also used to update the state of a given active communication.</semantics>
                <parameter>
                    <name>SenderEmitterID</name>
                    <dataType>LVCID</dataType>
                    <semantics>JLVC Identifier of the emitter.</semantics>
                </parameter>
                <parameter>
                    <name>SenderPosition</name>
                    <dataType>LocationStruct</dataType>
                    <semantics>Sender GCC Location in the world.</semantics>
                </parameter>
                <parameter>
                    <name>ReceiverEmitterID</name>
                    <dataType>LVCID</dataType>
                    <semantics>JLVC Identifier of the emitter.</semantics>
                </parameter>
                <parameter>
                    <name>ReceiverPosition</name>
                    <dataType>LocationStruct</dataType>
                    <semantics>Receivers GCC Location in the world.</semantics>
                </parameter>
                <parameter>
                    <name>SenderEventID</name>
                    <dataType>EntityIdentifierStruct</dataType>
                    <semantics>Sender TAG used to track states of the communication request</semantics>
                </parameter>
                <parameter>
                    <name>ActionRequestCode</name>
                    <dataType>CommsRequestEnum8</dataType>
                    <semantics>The request action or state change of the given communication request.</semantics>
                </parameter>
                <parameter>
                    <name>SenderEmitterName</name>
                    <dataType>RTIobjectId</dataType>
                    <semantics>The RTI name of the emitter object used by the sender</semantics>
                </parameter>
                <parameter>
                    <name>ReceiverEmitterName</name>
                    <dataType>RTIobjectId</dataType>
                    <semantics>The RTI name of the emitter object used by the receiver</semantics>
                </parameter>
            </interactionClass>
        </interactionClass>
    </interactions>
