{
  "name": "fom-viewer",
  "version": "0.0.11",
  "description": "Single page HTML viewer for IEEE 1516 FOM files",
  "scripts": {
    "lint": "eslint test/",
    "lint:fix": "eslint test/ --fix",
    "build": "node scripts/build.js",
    "build:dev": "node scripts/build.js --external",
    "build:map": "node scripts/build.js --sourcemap",
    "test": "cd test && npm test",
    "test:combined": "npm run build && cd test && npm run test -- --combined"
  },
  "devDependencies": {
    "eslint": "^8.57.1"
  },
  "keywords": [
    "fom",
    "hla",
    "viewer"
  ],
  "author": "",
  "license": "MIT"
}
